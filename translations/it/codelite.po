#: wxcrafter/controls/rich_text_ctrl_wrapper.cpp:63 wxcrafter/controls/search_ctrl_wrapper.cpp:25 wxcrafter/controls/text_ctrl_wrapper.cpp:33
msgid ""
"Respond to a wxEVT_COMMAND_TEXT_UPDATED event, generated when the text changes.\n"
