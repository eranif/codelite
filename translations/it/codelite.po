"\n"
"$parent: si espande nel nome del genitore del controllo personalizzato\n"
"$nome: si espande nel nome del membro C++\n"
"$id: l'ID del controllo\n"
"\n"
"Esempio:\n"
"$nome = nuovo MioControl($parent, $id)"

